  "required": [
    "agentCount",
    "agents",
    "callId",
    "completedAgentCount",
    "failedAgentCount",
    "logs",
    "phases",
    "runningAgentCount",
    "startedAtMs",
    "status",
    "threadId",
    "turnId",
    "updatedAtMs",
