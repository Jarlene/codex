            "integer",
            "null"
          ]
        },
        "error": {
          "type": [
            "string",
            "null"
          ]
        },
        "id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "model": {
          "type": [
            "string",
            "null"
          ]
        },
        "phase": {
          "type": [
            "string",
            "null"
          ]
        },
        "prompt": {
          "type": "string"
        },
        "startedAtMs": {
          "format": "int64",
